<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_vertical"
        android:minHeight="560dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="🎮"
            android:textSize="52sp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="VoxLink"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Gaming Voice Chat"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="44dp" />

        <!-- Your Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR NAME"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="e.g. Player123"
            android:textColor="#FFFFFF"
            android:textColorHint="#3A3A3A"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPersonName"
            android:maxLength="20"
            android:layout_marginBottom="24dp" />

        <!-- Room Hash -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROOM HASH"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_hash"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Paste hash from dashboard…"
            android:textColor="#FFFFFF"
            android:textColorHint="#3A3A3A"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textVisiblePassword|textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <!-- Live decoded status -->
        <TextView
            android:id="@+id/tv_hash_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingStart="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="28dp"
            android:visibility="gone" />

        <!-- Join Button -->
        <Button
            android:id="@+id/btn_join"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="JOIN ROOM"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:backgroundTint="#4ADE80" />

    </LinearLayout>
</ScrollView>
